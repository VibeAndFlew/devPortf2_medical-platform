{
  "name": "medica-healthcare",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise healthcare portal — patient management, appointment scheduling, telemedicine, electronic health records, prescription management, secure messaging.",
  "author": "MEDICA Health Systems",
  "license": "MIT",
  "homepage": "https://medica-health.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/medica/healthcare-portal.git"
  },
  "bugs": {
    "url": "https://github.com/medica/healthcare-portal/issues"
  },
  "keywords": [
    "healthcare",
    "ehr",
    "telemedicine",
    "hipaa",
    "patient-portal",
    "nextjs",
    "react",
    "typescript",
    "tailwindcss",
    "shadcn-ui"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev -p 4004",
    "build": "next build",
    "start": "next start -p 4004",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "analyze": "ANALYZE=true next build",
    "clean": "rimraf .next out dist",
    "docker:build": "docker build -t medica-healthcare .",
    "docker:run": "docker run -p 4004:4004 medica-healthcare",
    "preview": "next build && next start -p 4004",
    "db:seed": "tsx scripts/seed.ts",
    "prepare": "husky || true"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "framer-motion": "^12",
    "lucide-react": "^0.400",
    "class-variance-authority": "^0.7",
    "clsx": "^2.1",
    "tailwind-merge": "^3",
    "tailwindcss-animate": "^1",
    "zod": "^3",
    "@radix-ui/react-slot": "^1",
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-dropdown-menu": "^1",
    "@radix-ui/react-select": "^1",
    "@radix-ui/react-tabs": "^1",
    "@radix-ui/react-avatar": "^1",
    "@radix-ui/react-toast": "^1",
    "@radix-ui/react-label": "^1",
    "@radix-ui/react-separator": "^1",
    "@radix-ui/react-popover": "^1",
    "@radix-ui/react-tooltip": "^1",
    "@radix-ui/react-scroll-area": "^1",
    "@radix-ui/react-switch": "^1",
    "@radix-ui/react-checkbox": "^1",
    "@radix-ui/react-progress": "^1",
    "@radix-ui/react-alert-dialog": "^1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "prettier": "^3",
    "prettier-plugin-tailwindcss": "^0.6",
    "rimraf": "^6",
    "husky": "^9",
    "tsx": "^4"
  }
}

# ─── MEDICA Healthcare Platform ───────────────────────────────────────────────
# Environment Configuration
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.

# ─── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:4004
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_APP_NAME=MEDICA Healthcare

# ─── API & Backend ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api
API_INTERNAL_URL=http://localhost:8000
NEXT_PUBLIC_API_VERSION=v1

# ─── Authentication ───────────────────────────────────────────────────────────
AUTH_SECRET=generate-a-random-secret-with-openssl-rand-64-hex
AUTH_URL=http://localhost:4004
NEXT_PUBLIC_AUTH_PROVIDER=credentials
AUTH_SESSION_MAX_AGE=28800

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/medica
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis (Session Store / Cache) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TOKEN_BLACKLIST_TTL=86400

# ─── HIPAA Audit ──────────────────────────────────────────────────────────────
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2555
AUDIT_LOG_LEVEL=info

# ─── Encryption (PHI at rest) ─────────────────────────────────────────────────
ENCRYPTION_KEY=generate-a-256-bit-key-with-openssl-rand-32-hex
ENCRYPTION_ALGORITHM=aes-256-gcm

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.medica-health.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@medica-health.com

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=s3
STORAGE_BUCKET=medica-healthcare-phi
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=

# ─── Telemedicine ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_VIDEO_SDK_URL=https://video.medica-health.com
VIDEO_API_KEY=
VIDEO_API_SECRET=
VIDEO_RECORDING_ENABLED=false

# ─── Monitoring & Observability ───────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=medica-healthcare

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Feature Flags ────────────────────────────────────────────────────────────
NEXT_PUBLIC_FEATURE_TELEMEDICINE=true
NEXT_PUBLIC_FEATURE_E_PRESCRIBE=true
NEXT_PUBLIC_FEATURE_LABS_INTEGRATION=false
NEXT_PUBLIC_FEATURE_AI_ASSIST=false
